# Server Config
PORT=5000
JWT_SECRET=your_jwt_secret_key_here
NODE_ENV=development

# Frontend origin allowed to call this API (CORS). Set this to your deployed frontend URL in production.
FRONTEND_URL=http://localhost:3000

# Database Config (PostgreSQL)
# If left blank/commented out, the backend will automatically fallback to SQLite file 'crimegpt.sqlite'
# DATABASE_URL=postgresql://username:password@localhost:5432/crimegpt
# PGHOST=localhost
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=crimegpt
# PGPORT=5432
USE_SQLITE=true

# AI Services
# If left blank, the app will run with a localized rule-based recommendation fallback (no external API needed)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Email / MFA (OTP-on-login)
# If EMAIL_USER/EMAIL_PASS are left blank, login OTPs are returned directly in the API
# response (only when NODE_ENV is not 'production') so the app stays testable without
# setting up a real mailbox. For Gmail, use an "App Password", not your normal password:
# https://support.google.com/accounts/answer/185833
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="CrimeGPT Security" <your_email@gmail.com>

